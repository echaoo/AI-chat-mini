{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "jsx": "preserve",
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/h5/*"
      ]
    },
    "types": [
      "vite/client"
    ],
    "skipLibCheck": true
  },
  "include": [
    "src/h5/**/*.ts",
    "src/h5/**/*.d.ts",
    "src/h5/**/*.tsx",
    "src/h5/**/*.vue",
    "vite.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
